# ===== Animation Assistant — environment configuration =====
# Copy to ".env" and fill real values. NEVER commit ".env".

# --- Admin login (required to use the tools) ---
# WARNING: if password contains "#", fly secrets import will truncate at "#"
# (treated as comment in .env format). Use "!" instead. See risks.md.
ADMIN_PASSWORD=changeme!
# Secret used to sign auth cookies (optional; defaults to ADMIN_PASSWORD)
AUTH_SECRET=

# --- OpenRouter (outline + script + storyboard; Gemini models) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Azure storage ---
# animationasistant storage account (resource group: animation-asistant)
# KeyVault: AZURE-STORAGE-CONN-STR-AA
# Azure Portal: https://portal.azure.com/.../storageAccounts/animationasistant/overview
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER=projects
# Editable generation prompts live in their own container (seeded on boot)
AZURE_PROMPTS_CONTAINER=prompts

# --- Image generation (Phase 3) ---
IMAGE_API_KEY=
IMAGE_MODEL=

# --- Audio / TTS (Phase 4) ---
TTS_API_KEY=
TTS_VOICE=

# --- fal.ai (music + sound effects) ---
FAL_KEY=

# --- Fly.io deploy token (local machine only) ---
FLY_API_TOKEN=

# --- Overrides (optional) ---
# PORT=8080
# WEB_DIR=web
# OTHER_DIR=other
